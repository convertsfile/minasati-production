APP_NAME=Minassati
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-api-domain.com

APP_LOCALE=ar
APP_FALLBACK_LOCALE=ar
APP_FAKER_LOCALE=ar_SA

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=eduplatform
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=b2
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

SANCTUM_STATE_DURATION=525600

# ════════════════════════════════════════
# CORS — Add your Netlify frontend URL here
# ════════════════════════════════════════
CORS_ALLOWED_ORIGINS=https://your-netlify-site.netlify.app

# ════════════════════════════════════════
# Backblaze B2 (File & Video Storage)
# ════════════════════════════════════════
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET=minassati
B2_BUCKET_ID=
B2_REGION=us-east-005
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com

# Public bucket (optional for downloads)
B2_BUCKET_PUBLIC=minassati-public
B2_BUCKET_ID_PUBLIC=

# ════════════════════════════════════════
# VOD Engine (Go video processing worker)
# ════════════════════════════════════════
JWT_SECRET=
GO_ENGINE_URL=http://127.0.0.1:8080

# ════════════════════════════════════════
# Reverb (WebSocket for video processing progress)
# ════════════════════════════════════════
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8081
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ════════════════════════════════════════
# Twilio (SMS / OTP)
# ════════════════════════════════════════
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ════════════════════════════════════════
# Payment Gateways (Manual — not used in code, kept for reference)
# ════════════════════════════════════════
FAWRY_MERCHANT_CODE=
FAWRY_API_KEY=
FAWRY_SECRET_KEY=

VODAFONE_CASH_MERCHANT_CODE=
VODAFONE_CASH_API_KEY=
VODAFONE_CASH_SECRET_KEY=

# ════════════════════════════════════════
# Legacy / unused (kept for safety)
# ════════════════════════════════════════
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

VDOCIPHER_API_KEY=
VDOCIPHER_API_SECRET=
