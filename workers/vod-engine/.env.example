# ══════════════════════════════════════════════════════════════
# VOD Engine v2.0 — Configuration Template
# ══════════════════════════════════════════════════════════════
# Copy to .env and fill in your actual values.
# NEVER commit the actual .env file to version control.

# ── Server ──────────────────────────────────────────────────
PORT=8080
ALLOWED_ADMIN_ORIGIN=http://localhost:3002

# ── Backblaze B2 (Object Storage) ──────────────────────────
B2_KEY_ID=your_b2_key_id_here
B2_APP_KEY=your_b2_app_key_here
B2_BUCKET_NAME=your_bucket_name
B2_BUCKET_ID=your_bucket_id_here
B2_REGION=us-east-005
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com

# ── Laravel Backend ─────────────────────────────────────────
JWT_SECRET=change_this_to_a_strong_random_secret
LARAVEL_URL=http://127.0.0.1:8000
LARAVEL_PUBLIC_URL=http://127.0.0.1:8000

# ── Directories ─────────────────────────────────────────────
VOD_WORK_DIR=/var/tmp/vod-engine
VOD_QUEUE_DIR=/var/lib/vod-engine/queue
VOD_LOG_DIR=/var/log/vod-engine
VOD_CRASH_DIR=/var/log/vod-engine/crash

# ── Concurrency & Queue ─────────────────────────────────────
MAX_CONCURRENT_JOBS=1
MAX_QUEUE_SIZE=1000

# ── Resource Guardian Thresholds (OPS-14) ──────────────────
MAX_CPU_LOAD_AVG=4.5
RECOVERY_HYSTERESIS=0.5
MIN_FREE_RAM_MB=1536
MIN_FREE_SWAP_MB=1024
MIN_FREE_DISK_GB=15
MAX_DISK_IO_PCT=75.0
# MAX_NETWORK_MBPS: Maximum network outbound in Mbps before guardian blocks new jobs.
# Default 225 = 75% of a 300 Mbps port. Set to 0 to disable network throttling.
MAX_NETWORK_MBPS=225.0
MAX_WORK_DIR_USAGE_GB=75
MAX_PER_JOB_DISK_GB=25

# ── NVMe Wear Monitoring (OPS-22) ──────────────────────────
NVME_WEAR_WARN_PCT=80
NVME_WEAR_CRIT_PCT=95
NVME_CHECK_INTERVAL_M=5

# ── FFmpeg Resource Limits ──────────────────────────────────
CPU_AFFINITY_MASK=0-4
FFMPEG_THREADS=2
FFMPEG_PRESET=medium
FFMPEG_NICE=15
FFMPEG_IONICE_CLASS=2
FFMPEG_IONICE_LEVEL=7

# ── Retry ───────────────────────────────────────────────────
MAX_RETRIES=3
RETRY_BASE_DELAY_S=30

# ── Shutdown ────────────────────────────────────────────────
GRACEFUL_TIMEOUT_S=300

# ── Polling / Monitoring ────────────────────────────────────
RESOURCE_POLL_INTERVAL_S=10
MONITOR_INTERVAL_S=5

# ── Network ─────────────────────────────────────────────────
DOWNLOAD_RATE_LIMIT_KBPS=0
UPLOAD_CONCURRENCY=3

# ── HLS ─────────────────────────────────────────────────────
HLS_SEGMENT_DURATION_S=6
HLS_KEYFRAME_INTERVAL=48

# ── Stderr Capture ──────────────────────────────────────────
MAX_STDERR_CAPTURE_BYTES=4096
